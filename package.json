{
  "name": "reddie",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --publish=never",
    "test": "vitest run",
    "release:patch": "npm version patch -m \"chore(release): v%s\" && git push --follow-tags",
    "release:minor": "npm version minor -m \"chore(release): v%s\" && git push --follow-tags",
    "release:major": "npm version major -m \"chore(release): v%s\" && git push --follow-tags"
  },
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "sortablejs": "^1.15.7"
  },
  "build": {
    "appId": "com.buluma.reddie",
    "productName": "reddie",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "**/*",
      "!.env",
      "!.env.example",
      "!src/__tests__/**"
    ],
    "mac": {
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
